# CyberSec Alert SaaS - Environment Configuration
# Copy this file to .env and update values. Do not commit real secrets.

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# SQLite (local):
DATABASE_URL=sqlite:///cybersec_alerts.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://cybersec_user:password@db:5432/cybersec_db
# Optional: if omitted, backend/config.py derives this automatically for common DB URL formats
# ASYNC_DATABASE_URL=postgresql+asyncpg://cybersec_user:password@db:5432/cybersec_db

# Application
APP_NAME=CyberSec Alert SaaS
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://yourdomain.com"]

# Scheduler
SCRAPER_INTERVAL_HOURS=6

# Email (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
FROM_EMAIL=noreply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# NVD API (optional)
NVD_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Integrations (optional)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
SIEM_HEC_URL=
SIEM_HEC_TOKEN=

# Cisco API credentials (optional)
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=

# Misc
SENTRY_DSN=
ENVIRONMENT=development
